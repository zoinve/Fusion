<Application
    x:Class="YPM.UI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:helpers="using:YPM.UI.Helpers">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
                <ResourceDictionary Source="Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <helpers:StringToBooleanConverter x:Key="StringToBooleanConverter" />
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="YpmAccentBrush" Color="#C92A2A" />
                    <SolidColorBrush x:Key="YpmSubtleBrush" Color="#FFF4E6" />
                    <SolidColorBrush x:Key="PlayerBarBackgroundBrush" Color="#FEF0F0" />
                    <SolidColorBrush x:Key="PlayerBarBorderBrush" Color="#E8C8C8" />
                    <SolidColorBrush x:Key="PlayerBarSubtleFillBrush" Color="#F0D0D0" />
                    <SolidColorBrush x:Key="PlayerBarTrackFillBrush" Color="#E8C0C0" />
                    <SolidColorBrush x:Key="PlayerBarAccentBrush" Color="#E799B0" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="YpmAccentBrush" Color="#C92A2A" />
                    <SolidColorBrush x:Key="YpmSubtleBrush" Color="#FFF4E6" />
                    <SolidColorBrush x:Key="PlayerBarBackgroundBrush" Color="#FEF0F0" />
                    <SolidColorBrush x:Key="PlayerBarBorderBrush" Color="#E8C8C8" />
                    <SolidColorBrush x:Key="PlayerBarSubtleFillBrush" Color="#F0D0D0" />
                    <SolidColorBrush x:Key="PlayerBarTrackFillBrush" Color="#E8C0C0" />
                    <SolidColorBrush x:Key="PlayerBarAccentBrush" Color="#E799B0" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="YpmAccentBrush" Color="#F03E3E" />
                    <SolidColorBrush x:Key="YpmSubtleBrush" Color="#2A1A1A" />
                    <SolidColorBrush x:Key="PlayerBarBackgroundBrush" Color="#1A1111" />
                    <SolidColorBrush x:Key="PlayerBarBorderBrush" Color="#2A1111" />
                    <SolidColorBrush x:Key="PlayerBarSubtleFillBrush" Color="#2A1818" />
                    <SolidColorBrush x:Key="PlayerBarTrackFillBrush" Color="#3A2020" />
                    <SolidColorBrush x:Key="PlayerBarAccentBrush" Color="#E799B0" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
