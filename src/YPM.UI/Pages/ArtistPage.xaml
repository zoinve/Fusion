<Page
    x:Class="YPM.UI.Pages.ArtistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:YPM.UI.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="using:YPM.Core.Models"
    xmlns:vm="using:YPM.UI.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:UriImageSourceConverter x:Key="UriImageSourceConverter" />
        <helpers:StringToBooleanConverter x:Key="StringToBooleanConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="ArtistTrackListViewStyle" TargetType="ListView">
            <Setter Property="IsItemClickEnabled" Value="True" />
            <Setter Property="SelectionMode" Value="None" />
            <Setter Property="ScrollViewer.VerticalScrollMode" Value="Disabled" />
            <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <Grid x:Name="LayoutRoot">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideHeaderState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="920" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeaderGrid.ColumnSpacing" Value="28" />
                        <Setter Target="HeaderGrid.RowSpacing" Value="0" />
                        <Setter Target="HeaderCoverColumn.Width" Value="Auto" />
                        <Setter Target="HeaderInfoColumn.Width" Value="*" />
                        <Setter Target="HeaderCoverContainer.(Grid.Column)" Value="0" />
                        <Setter Target="HeaderCoverContainer.(Grid.Row)" Value="0" />
                        <Setter Target="HeaderCoverContainer.HorizontalAlignment" Value="Left" />
                        <Setter Target="HeaderInfoPanel.(Grid.Column)" Value="1" />
                        <Setter Target="HeaderInfoPanel.(Grid.Row)" Value="0" />
                        <Setter Target="HeaderInfoPanel.Margin" Value="0" />
                        <Setter Target="HeaderInfoPanel.HorizontalAlignment" Value="Stretch" />
                        <Setter Target="HeaderCoverContainer.Width" Value="280" />
                        <Setter Target="HeaderCoverContainer.Height" Value="280" />
                        <Setter Target="HeaderCoverImage.Width" Value="280" />
                        <Setter Target="HeaderCoverImage.Height" Value="280" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="NarrowHeaderState">
                    <VisualState.Setters>
                        <Setter Target="HeaderGrid.ColumnSpacing" Value="0" />
                        <Setter Target="HeaderGrid.RowSpacing" Value="20" />
                        <Setter Target="HeaderCoverColumn.Width" Value="*" />
                        <Setter Target="HeaderInfoColumn.Width" Value="0" />
                        <Setter Target="HeaderCoverContainer.(Grid.Column)" Value="0" />
                        <Setter Target="HeaderCoverContainer.(Grid.Row)" Value="0" />
                        <Setter Target="HeaderCoverContainer.HorizontalAlignment" Value="Center" />
                        <Setter Target="HeaderInfoPanel.(Grid.Column)" Value="0" />
                        <Setter Target="HeaderInfoPanel.(Grid.Row)" Value="1" />
                        <Setter Target="HeaderInfoPanel.Margin" Value="0" />
                        <Setter Target="HeaderInfoPanel.HorizontalAlignment" Value="Stretch" />
                        <Setter Target="HeaderCoverContainer.Width" Value="220" />
                        <Setter Target="HeaderCoverContainer.Height" Value="220" />
                        <Setter Target="HeaderCoverImage.Width" Value="220" />
                        <Setter Target="HeaderCoverImage.Height" Value="220" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar
            IsOpen="{x:Bind ViewModel.ErrorMessage, Converter={StaticResource StringToBooleanConverter}, Mode=OneWay}"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            Severity="Error" />

        <ProgressRing
            Grid.Row="1"
            Width="48"
            Height="48"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

        <ScrollViewer Grid.Row="1" x:Name="MainScrollViewer">
            <StackPanel
                HorizontalAlignment="Stretch"
                Padding="40,24,40,40"
                Spacing="28">

                <Button
                    HorizontalAlignment="Left"
                    Click="OnBackClick"
                    CornerRadius="18"
                    Padding="14,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72B;" FontSize="14" />
                        <TextBlock Text="返回" />
                    </StackPanel>
                </Button>

                <Grid x:Name="HeaderGrid" ColumnSpacing="28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="HeaderCoverColumn" Width="Auto" />
                        <ColumnDefinition x:Name="HeaderInfoColumn" Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        x:Name="HeaderCoverContainer"
                        Width="280"
                        Height="280"
                        CornerRadius="140"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <Image
                            x:Name="HeaderCoverImage"
                            Width="280"
                            Height="280"
                            Source="{x:Bind ViewModel.ArtistCoverUrl, Converter={StaticResource UriImageSourceConverter}, ConverterParameter=full, Mode=OneWay}"
                            Stretch="UniformToFill" />
                    </Border>

                    <StackPanel
                        x:Name="HeaderInfoPanel"
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Spacing="12">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Opacity="0.6"
                            Text="艺人" />
                        <TextBlock
                            FontSize="40"
                            FontWeight="Bold"
                            MaxLines="3"
                            Text="{x:Bind ViewModel.ArtistName, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            FontSize="14"
                            Opacity="0.68"
                            Text="{x:Bind ViewModel.StatisticsText, Mode=OneWay}" />
                        <TextBlock
                            FontSize="14"
                            Opacity="0.68"
                            Text="{x:Bind ViewModel.IdentityText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords"
                            Visibility="{x:Bind ViewModel.IdentityText, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />

                        <StackPanel
                            Spacing="6"
                            Visibility="{x:Bind ViewModel.HasDescription, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Opacity="0.6"
                                Text="艺人介绍" />
                            <TextBlock
                                FontSize="14"
                                Opacity="0.68"
                                MaxLines="{x:Bind ViewModel.DescriptionMaxLines, Mode=OneWay}"
                                Text="{x:Bind ViewModel.FullDescription, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="WrapWholeWords" />
                            <Button
                                HorizontalAlignment="Left"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="4,2"
                                Click="OnToggleDescriptionClick"
                                Visibility="{x:Bind ViewModel.HasLongDescription, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                <TextBlock FontSize="12" Opacity="0.5" Text="{x:Bind ViewModel.DescriptionExpandText, Mode=OneWay}" />
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,12,0,0">
                            <Button
                                Click="OnFollowClick"
                                CornerRadius="20"
                                Padding="24,10"
                                FontSize="14">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="{x:Bind ViewModel.FollowGlyph, Mode=OneWay}" FontSize="14" />
                                    <TextBlock Text="{x:Bind ViewModel.FollowText, Mode=OneWay}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="20"
                    Visibility="{x:Bind ViewModel.HasLatestRelease, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="132" Height="132" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="16">
                            <Image
                                Width="132"
                                Height="132"
                                Source="{x:Bind ViewModel.LatestReleaseCoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                                Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Opacity="0.6" Text="最新发布" />
                            <TextBlock
                                FontSize="22"
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.LatestReleaseName, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="14" Opacity="0.68" Text="{x:Bind ViewModel.LatestReleaseDateText, Mode=OneWay}" />
                            <TextBlock FontSize="14" Opacity="0.6" Text="{x:Bind ViewModel.LatestReleaseMetaText, Mode=OneWay}" />
                            <Button
                                HorizontalAlignment="Left"
                                Click="OnLatestReleaseClick"
                                CornerRadius="18"
                                Padding="16,8">
                                <TextBlock Text="查看专辑" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Spacing="10" Visibility="{x:Bind ViewModel.HasPopularTracks, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="热门歌曲" />
                    <ListView
                        ItemsSource="{x:Bind ViewModel.PopularTracks, Mode=OneWay}"
                        Style="{StaticResource ArtistTrackListViewStyle}"
                        ItemClick="OnTrackItemClick">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="model:TrackInfo">
                                <Grid Padding="8,6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Opacity="0.5"
                                        Text="{x:Bind DisplayIndex}" />

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind Name}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            FontSize="12"
                                            Opacity="0.68"
                                            Text="{x:Bind AlbumName}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Grid
                                        Grid.Column="2"
                                        VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            FontSize="13"
                                            Glyph="{x:Bind LikeGlyph, Mode=OneWay}"
                                            HorizontalAlignment="Center"
                                            Opacity="0.7" />
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            HorizontalAlignment="Right"
                                            Opacity="0.68"
                                            Text="{x:Bind DurationText}" />
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.HasAlbums, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="专辑" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Albums, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout
                                ItemsJustification="Start"
                                MinColumnSpacing="18"
                                MinItemWidth="180"
                                MinRowSpacing="22"
                                Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ArtistAlbumCardItem">
                                <StackPanel Width="180" Spacing="10" Tag="{x:Bind Id}" Tapped="OnAlbumTapped">
                                    <Border CornerRadius="18">
                                        <Image
                                            Width="180"
                                            Height="180"
                                            Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                                            Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.6"
                                        Text="{x:Bind MetaText}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.HasEpsAndSingles, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="EP / Single" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.EpsAndSingles, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout
                                ItemsJustification="Start"
                                MinColumnSpacing="18"
                                MinItemWidth="180"
                                MinRowSpacing="22"
                                Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ArtistAlbumCardItem">
                                <StackPanel Width="180" Spacing="10" Tag="{x:Bind Id}" Tapped="OnAlbumTapped">
                                    <Border CornerRadius="18">
                                        <Image
                                            Width="180"
                                            Height="180"
                                            Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                                            Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.6"
                                        Text="{x:Bind MetaText}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
