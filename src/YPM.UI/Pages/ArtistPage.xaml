<Page
    x:Class="YPM.UI.Pages.ArtistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:YPM.UI.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="using:YPM.Core.Models"
    xmlns:vm="using:YPM.UI.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:UriImageSourceConverter x:Key="UriImageSourceConverter" />
        <helpers:StringToBooleanConverter x:Key="StringToBooleanConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="ArtistTrackListViewStyle" TargetType="ListView">
            <Setter Property="IsItemClickEnabled" Value="True" />
            <Setter Property="SelectionMode" Value="None" />
            <Setter Property="ScrollViewer.VerticalScrollMode" Value="Disabled" />
            <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar
            IsOpen="{x:Bind ViewModel.ErrorMessage, Converter={StaticResource StringToBooleanConverter}, Mode=OneWay}"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            Severity="Error" />

        <ProgressRing
            Grid.Row="1"
            Width="48"
            Height="48"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

        <ScrollViewer Grid.Row="1" x:Name="MainScrollViewer">
            <StackPanel Width="1080" HorizontalAlignment="Center" Padding="28,24,28,40" Spacing="28">
                <Button
                    HorizontalAlignment="Left"
                    Click="OnBackClick"
                    CornerRadius="18"
                    Padding="14,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72B;" FontSize="14" />
                        <TextBlock Text="返回" />
                    </StackPanel>
                </Button>

                <Grid ColumnSpacing="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="280" Height="280" Background="#171717" CornerRadius="140">
                        <Image
                            Width="280"
                            Height="280"
                            Source="{x:Bind ViewModel.ArtistCoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                            Stretch="UniformToFill" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="12">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Opacity="0.55"
                            Text="艺人" />
                        <TextBlock
                            FontSize="36"
                            FontWeight="Bold"
                            MaxLines="3"
                            Text="{x:Bind ViewModel.ArtistName, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            FontSize="14"
                            Opacity="0.72"
                            Text="{x:Bind ViewModel.StatisticsText, Mode=OneWay}" />
                        <TextBlock
                            FontSize="14"
                            Opacity="0.6"
                            Text="{x:Bind ViewModel.IdentityText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords"
                            Visibility="{x:Bind ViewModel.IdentityText, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                        <TextBlock
                            FontSize="14"
                            MaxLines="{x:Bind ViewModel.DescriptionMaxLines, Mode=OneWay}"
                            Text="{x:Bind ViewModel.FullDescription, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="WrapWholeWords"
                            Visibility="{x:Bind ViewModel.HasDescription, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                        <Button
                            HorizontalAlignment="Left"
                            Background="Transparent"
                            Click="OnToggleDescriptionClick"
                            Padding="4,2"
                            Visibility="{x:Bind ViewModel.HasLongDescription, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                            <TextBlock FontSize="12" Opacity="0.55" Text="{x:Bind ViewModel.DescriptionExpandText, Mode=OneWay}" />
                        </Button>

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            
                            <Button
                                Click="OnFollowClick"
                                CornerRadius="20"
                                Padding="24,10">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="{x:Bind ViewModel.FollowGlyph, Mode=OneWay}" FontSize="14" />
                                    <TextBlock FontSize="15" Text="{x:Bind ViewModel.FollowText, Mode=OneWay}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    CornerRadius="20"
                    Visibility="{x:Bind ViewModel.HasLatestRelease, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="132" Height="132" Background="#1A1A1A" CornerRadius="16">
                            <Image
                                Width="132"
                                Height="132"
                                Source="{x:Bind ViewModel.LatestReleaseCoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                                Stretch="UniformToFill" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Opacity="0.55" Text="最新发布" />
                            <TextBlock
                                FontSize="22"
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.LatestReleaseName, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="14" Opacity="0.72" Text="{x:Bind ViewModel.LatestReleaseDateText, Mode=OneWay}" />
                            <TextBlock FontSize="14" Opacity="0.6" Text="{x:Bind ViewModel.LatestReleaseMetaText, Mode=OneWay}" />
                            <Button
                                HorizontalAlignment="Left"
                                Click="OnLatestReleaseClick"
                                CornerRadius="18"
                                Padding="16,8">
                                <TextBlock Text="查看专辑" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Spacing="10" Visibility="{x:Bind ViewModel.HasPopularTracks, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="热门歌曲" />
                    <ListView
                        ItemsSource="{x:Bind ViewModel.PopularTracks, Mode=OneWay}"
                        Style="{StaticResource ArtistTrackListViewStyle}"
                        ItemClick="OnTrackItemClick">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="model:TrackInfo">
                                <Grid Padding="8,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="96" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Grid.Column="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Opacity="0.45"
                                        Text="{x:Bind DisplayIndex}" />

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind Name}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            FontSize="13"
                                            Opacity="0.6"
                                            Text="{x:Bind AlbumName}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Grid
                                        Grid.Column="2"
                                        VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            FontSize="14"
                                            Glyph="{x:Bind LikeGlyph, Mode=OneWay}"
                                            HorizontalAlignment="Center"
                                            Opacity="0.4" />
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            HorizontalAlignment="Right"
                                            Opacity="0.5"
                                            Text="{x:Bind DurationText}" />
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.HasAlbums, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="专辑" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Albums, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout
                                ItemsJustification="Start"
                                MinColumnSpacing="18"
                                MinItemWidth="180"
                                MinRowSpacing="22"
                                Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ArtistAlbumCardItem">
                                <StackPanel Width="180" Spacing="10" Tag="{x:Bind Id}" Tapped="OnAlbumTapped">
                                    <Border Background="#171717" CornerRadius="18">
                                        <Image
                                            Width="180"
                                            Height="180"
                                            Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                                            Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="13"
                                        Opacity="0.6"
                                        Text="{x:Bind MetaText}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.HasEpsAndSingles, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="EP / Single" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.EpsAndSingles, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout
                                ItemsJustification="Start"
                                MinColumnSpacing="18"
                                MinItemWidth="180"
                                MinRowSpacing="22"
                                Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:ArtistAlbumCardItem">
                                <StackPanel Width="180" Spacing="10" Tag="{x:Bind Id}" Tapped="OnAlbumTapped">
                                    <Border Background="#171717" CornerRadius="18">
                                        <Image
                                            Width="180"
                                            Height="180"
                                            Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                                            Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind Name}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="13"
                                        Opacity="0.6"
                                        Text="{x:Bind MetaText}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
