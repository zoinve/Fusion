<Page
    x:Class="YPM.UI.Pages.AlbumPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:YPM.UI.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="using:YPM.Core.Models"
    xmlns:vm="using:YPM.UI.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:UriImageSourceConverter x:Key="UriImageSourceConverter" />
        <helpers:StringToBooleanConverter x:Key="StringToBooleanConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="AlbumTrackListViewStyle" TargetType="ListView">
            <Setter Property="IsItemClickEnabled" Value="True" />
            <Setter Property="SelectionMode" Value="None" />
            <Setter Property="ScrollViewer.VerticalScrollMode" Value="Disabled" />
            <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <Grid x:Name="LayoutRoot">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideHeaderState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="920" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeaderGrid.ColumnSpacing" Value="28" />
                        <Setter Target="HeaderGrid.RowSpacing" Value="0" />
                        <Setter Target="HeaderCoverColumn.Width" Value="Auto" />
                        <Setter Target="HeaderInfoColumn.Width" Value="*" />
                        <Setter Target="HeaderCoverContainer.(Grid.Column)" Value="0" />
                        <Setter Target="HeaderCoverContainer.(Grid.Row)" Value="0" />
                        <Setter Target="HeaderCoverContainer.HorizontalAlignment" Value="Left" />
                        <Setter Target="HeaderInfoPanel.(Grid.Column)" Value="1" />
                        <Setter Target="HeaderInfoPanel.(Grid.Row)" Value="0" />
                        <Setter Target="HeaderInfoPanel.Margin" Value="0" />
                        <Setter Target="HeaderInfoPanel.HorizontalAlignment" Value="Stretch" />
                        <Setter Target="HeaderCoverContainer.Width" Value="280" />
                        <Setter Target="HeaderCoverContainer.Height" Value="280" />
                        <Setter Target="HeaderCoverImage.Width" Value="280" />
                        <Setter Target="HeaderCoverImage.Height" Value="280" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="NarrowHeaderState">
                    <VisualState.Setters>
                        <Setter Target="HeaderGrid.ColumnSpacing" Value="0" />
                        <Setter Target="HeaderGrid.RowSpacing" Value="20" />
                        <Setter Target="HeaderCoverColumn.Width" Value="*" />
                        <Setter Target="HeaderInfoColumn.Width" Value="0" />
                        <Setter Target="HeaderCoverContainer.(Grid.Column)" Value="0" />
                        <Setter Target="HeaderCoverContainer.(Grid.Row)" Value="0" />
                        <Setter Target="HeaderCoverContainer.HorizontalAlignment" Value="Center" />
                        <Setter Target="HeaderInfoPanel.(Grid.Column)" Value="0" />
                        <Setter Target="HeaderInfoPanel.(Grid.Row)" Value="1" />
                        <Setter Target="HeaderInfoPanel.Margin" Value="0" />
                        <Setter Target="HeaderInfoPanel.HorizontalAlignment" Value="Stretch" />
                        <Setter Target="HeaderCoverContainer.Width" Value="220" />
                        <Setter Target="HeaderCoverContainer.Height" Value="220" />
                        <Setter Target="HeaderCoverImage.Width" Value="220" />
                        <Setter Target="HeaderCoverImage.Height" Value="220" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar
            x:Name="ErrorInfoBar"
            IsOpen="{x:Bind ViewModel.ErrorMessage, Converter={StaticResource StringToBooleanConverter}, Mode=OneWay}"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
            Severity="Error" />

        <ScrollViewer Grid.Row="1" x:Name="MainScrollViewer">
            <StackPanel 
                HorizontalAlignment="Stretch" 
                Padding="40,24,40,40" 
                Spacing="28">

                <Button
                    HorizontalAlignment="Left"
                    Click="OnBackClick"
                    CornerRadius="18"
                    Padding="14,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72B;" FontSize="14" />
                        <TextBlock Text="返回" />
                    </StackPanel>
                </Button>

                <Grid x:Name="HeaderGrid" ColumnSpacing="28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="HeaderCoverColumn" Width="Auto" />
                        <ColumnDefinition x:Name="HeaderInfoColumn" Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        x:Name="HeaderCoverContainer"
                        Width="280"
                        Height="280"
                        CornerRadius="16"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <Image
                            x:Name="HeaderCoverImage"
                            Width="280"
                            Height="280"
                            Source="{x:Bind ViewModel.Album.CoverUrl, Converter={StaticResource UriImageSourceConverter}, ConverterParameter=full, Mode=OneWay}"
                            Stretch="UniformToFill"
                            ImageFailed="OnAlbumCoverImageFailed" />
                    </Border>

                    <StackPanel
                        x:Name="HeaderInfoPanel"
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Spacing="12">
                        <TextBlock
                            Text="专辑"
                            FontSize="14"
                            Opacity="0.6"
                            FontWeight="SemiBold" />
                        <TextBlock
                            Text="{x:Bind ViewModel.Album.Name, Mode=OneWay}"
                            FontSize="40"
                            FontWeight="Bold"
                            TextWrapping="WrapWholeWords"
                            MaxLines="3"
                            TextTrimming="CharacterEllipsis" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="18" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                <Image
                                    Width="36"
                                    Height="36"
                                    Source="{x:Bind ViewModel.Album.Artist.CoverUrl, Converter={StaticResource UriImageSourceConverter}, ConverterParameter=full, Mode=OneWay}"
                                    Stretch="UniformToFill" />
                            </Border>
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.Album.Artist.Name, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <TextBlock
                            Text="{x:Bind ViewModel.AlbumInfo, Mode=OneWay}"
                            FontSize="14"
                            Opacity="0.68"
                            TextWrapping="WrapWholeWords" />

                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,12,0,0">
                            <Button
                                x:Name="SubscribeButton"
                                Click="OnSubscribeClick"
                                CornerRadius="20"
                                Padding="24,10"
                                FontSize="14">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="{x:Bind ViewModel.SubscribeGlyph, Mode=OneWay}" FontSize="14" />
                                    <TextBlock Text="{x:Bind ViewModel.SubscribeText, Mode=OneWay}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <StackPanel
                    Spacing="6"
                    Visibility="{x:Bind ViewModel.HasDescription, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <TextBlock Text="专辑介绍" FontSize="14" FontWeight="SemiBold" Opacity="0.6" />
                    <TextBlock
                        Text="{x:Bind ViewModel.Album.Description, Mode=OneWay}"
                        FontSize="14"
                        Opacity="0.68"
                        TextWrapping="WrapWholeWords"
                        MaxLines="{x:Bind ViewModel.DescriptionMaxLines, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                    <Button
                        Visibility="{x:Bind ViewModel.HasLongDescription, Mode=OneWay}"
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Padding="4,2"
                        Click="OnToggleDescriptionClick">
                        <TextBlock FontSize="12" Opacity="0.5" Text="{x:Bind ViewModel.DescriptionExpandText, Mode=OneWay}" />
                    </Button>
                </StackPanel>

                <ItemsRepeater ItemsSource="{x:Bind ViewModel.DiscGroups, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:TrackGroup">
                            <StackPanel Spacing="8" Margin="0,0,0,16">
                                <TextBlock
                                    Text="{x:Bind Header, Mode=OneWay}"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Opacity="0.5"
                                    Margin="12,0,0,0"
                                    Visibility="{x:Bind HasHeader, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />

                                <ListView
                                    ItemsSource="{x:Bind Tracks, Mode=OneWay}"
                                    Style="{StaticResource AlbumTrackListViewStyle}"
                                    ItemClick="OnTrackItemClick">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="model:TrackInfo">
                                            <Grid Padding="8,6" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="80" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    Grid.Column="0"
                                                    FontSize="14"
                                                    Opacity="0.5"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    Text="{x:Bind DisplayIndex}" />

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock
                                                        FontSize="14"
                                                        FontWeight="SemiBold"
                                                        TextTrimming="CharacterEllipsis">
                                                        <Run Text="{x:Bind Name}" />
                                                        <Run Text="{x:Bind DisplayAliasText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    </TextBlock>
                                                    <TextBlock
                                                        Text="{x:Bind ArtistsText}"
                                                        FontSize="12"
                                                        Opacity="0.68"
                                                        TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <Grid Grid.Column="2" VerticalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="32" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button
                                                        Width="28"
                                                        Height="28"
                                                        Padding="4"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="0"
                                                        Click="OnTrackLikeClick"
                                                        Tag="{x:Bind Id}">
                                                        <FontIcon
                                                            FontSize="13"
                                                            Glyph="{x:Bind LikeGlyph, Mode=OneWay}"
                                                            Opacity="0.7"
                                                            VerticalAlignment="Center" />
                                                    </Button>
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Text="{x:Bind DurationText}"
                                                        FontSize="12"
                                                        HorizontalAlignment="Right"
                                                        Opacity="0.68"
                                                        VerticalAlignment="Center" />
                                                </Grid>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
