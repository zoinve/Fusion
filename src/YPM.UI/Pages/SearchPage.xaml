<Page
    x:Class="YPM.UI.Pages.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:YPM.UI.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:YPM.UI.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:UriImageSourceConverter x:Key="UriImageSourceConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="SectionContainerStyle" TargetType="StackPanel">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Spacing" Value="18" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="MoreButtonStyle" TargetType="HyperlinkButton">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Padding" Value="24,8" />
        </Style>

        <DataTemplate x:Key="SongItemTemplate" x:DataType="vm:SearchItemInfo">
            <Grid
                Width="280"
                Height="64"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="12,0"
                ColumnSpacing="12"
                Tag="{x:Bind Id}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border
                    Grid.Column="0"
                    Width="44"
                    Height="44"
                    CornerRadius="6"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <Image
                        Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                        Stretch="UniformToFill" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        TextTrimming="CharacterEllipsis">
                        <Run Text="{x:Bind Name}" />
                        <Run Text="{x:Bind DisplayAliasText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </TextBlock>
                    <TextBlock
                        Text="{x:Bind Subtitle}"
                        FontSize="12"
                        Opacity="0.6"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AlbumItemTemplate" x:DataType="vm:SearchItemInfo">
            <StackPanel Width="150" Spacing="10" Background="Transparent" Tag="{x:Bind Id}">
                <Border Background="#141414" CornerRadius="14">
                    <Grid Width="150" Height="150">
                        <Image
                            Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                            Stretch="UniformToFill" />
                    </Grid>
                </Border>
                <TextBlock
                    Text="{x:Bind Name}"
                    FontSize="15"
                    FontWeight="SemiBold"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Text="{x:Bind Subtitle}"
                    Opacity="0.68"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ArtistItemTemplate" x:DataType="vm:SearchItemInfo">
            <StackPanel Width="150" Spacing="10" Background="Transparent" Tag="{x:Bind Id}">
                <Border Background="#111111" CornerRadius="75">
                    <Grid Width="150" Height="150">
                        <Image
                            Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                            Stretch="UniformToFill" />
                    </Grid>
                </Border>
                <TextBlock
                    Text="{x:Bind Name}"
                    HorizontalAlignment="Left"
                    FontSize="15"
                    FontWeight="SemiBold"
                    TextAlignment="Left"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="PlaylistItemTemplate" x:DataType="vm:SearchItemInfo">
            <StackPanel Width="150" Spacing="10" Background="Transparent" Tag="{x:Bind Id}">
                <Border Background="#141414" CornerRadius="14">
                    <Grid Width="150" Height="150">
                        <Image
                            Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                            Stretch="UniformToFill" />
                    </Grid>
                </Border>
                <TextBlock
                    Text="{x:Bind Name}"
                    FontSize="15"
                    FontWeight="SemiBold"
                    TextTrimming="CharacterEllipsis"
                    MaxLines="2"
                    TextWrapping="Wrap" />
                <TextBlock
                    Text="{x:Bind Subtitle}"
                    Opacity="0.68"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <!-- Empty / initial state: search box centered vertically -->
        <Border
            x:Name="EmptySearchBox"
            MaxWidth="3000"
            MinWidth="400"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="24"
            Padding="8,8"
            BorderThickness="1"
            BorderBrush="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            Visibility="{x:Bind ViewModel.ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
            <Grid ColumnSpacing="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon
                    Grid.Column="0"
                    Glyph="{x:Bind SearchGlyph}"
                    FontSize="20"
                    Opacity="0.5"
                    Margin="16,0,12,0"
                    VerticalAlignment="Center" />
                <TextBox
                    Grid.Column="1"
                    Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="搜索歌曲、专辑、歌手..."
                    BorderThickness="0"
                    FontSize="18"
                    VerticalAlignment="Center"
                    Padding="0,12"
                    KeyDown="OnSearchBoxKeyDown" />
                <Button
                    Grid.Column="2"
                    Content="清除"
                    Command="{x:Bind ViewModel.ClearSearchCommand}"
                    Visibility="{x:Bind ViewModel.HasSearchText, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                    Margin="4,0,8,0"
                    VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- Results state: search box at top, scrollable results below -->
        <Grid
            Visibility="{x:Bind ViewModel.HasSearched, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                MaxWidth="1280"
                HorizontalAlignment="Stretch"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="24"
                Padding="4,4"
                Margin="28,24,28,0"
                BorderThickness="1"
                BorderBrush="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <Grid ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon
                        Grid.Column="0"
                        Glyph="{x:Bind SearchGlyph}"
                        FontSize="16"
                        Opacity="0.5"
                        Margin="12,0,8,0"
                        VerticalAlignment="Center" />
                    <TextBox
                        Grid.Column="1"
                        Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="搜索歌曲、专辑、歌手..."
                        BorderThickness="0"
                        
                        FontSize="16"
                        VerticalAlignment="Center"
                        Padding="0,8"
                        KeyDown="OnSearchBoxKeyDown" />
                    <Button
                        Grid.Column="2"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Content="清除"
                        Command="{x:Bind ViewModel.ClearSearchCommand}"
                        Visibility="{x:Bind ViewModel.HasSearchText, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                        Margin="4,0,4,0"
                        VerticalAlignment="Center" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" x:Name="MainScrollViewer">
                <StackPanel HorizontalAlignment="Stretch" Padding="28,12,28,40" Spacing="36">
                <!-- Status -->
            <Grid HorizontalAlignment="Stretch" ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                        FontSize="14"
                        Opacity="0.6"
                        VerticalAlignment="Center" />
                </Grid>

                <!-- Songs section -->
                <StackPanel
                    Style="{StaticResource SectionContainerStyle}"
                    Visibility="{x:Bind ViewModel.HasSongs, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="歌曲" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Songs, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout
                                MinColumnSpacing="12"
                                MinItemWidth="280"
                                MinRowSpacing="8"
                                ItemsJustification="Start"
                                Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:SearchItemInfo">
                                <Grid
                                    Width="280"
                                    Height="64"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="8"
                                    Padding="12,0"
                                    ColumnSpacing="12"
                                    Tag="{x:Bind Id}"
                                    Tapped="OnSongTapped">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Grid.Column="0"
                                        Width="44"
                                        Height="44"
                                        CornerRadius="6"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <Image
                                            Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                                            Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            TextTrimming="CharacterEllipsis">
                                            <Run Text="{x:Bind Name}" />
                                            <Run Text="{x:Bind DisplayAliasText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </TextBlock>
                                        <TextBlock
                                            Text="{x:Bind Subtitle}"
                                            FontSize="12"
                                            Opacity="0.6"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <!-- More songs button -->
                    <HyperlinkButton
                        Style="{StaticResource MoreButtonStyle}"
                        Content="查看更多歌曲"
                        Visibility="{x:Bind ViewModel.HasMoreSongs, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                        Click="OnMoreSongsClick" />
                </StackPanel>

                <!-- Albums section -->
                <StackPanel
                    Style="{StaticResource SectionContainerStyle}"
                    Visibility="{x:Bind ViewModel.HasAlbums, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="专辑" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Albums, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout
                                MinColumnSpacing="14"
                                MinItemWidth="150"
                                MinRowSpacing="18"
                                ItemsJustification="Start"
                                Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:SearchItemInfo">
                                <StackPanel Width="150" Spacing="10" Background="Transparent" Tag="{x:Bind Id}" Tapped="OnAlbumTapped">
                                    <Border Background="#141414" CornerRadius="14">
                                        <Grid Width="150" Height="150">
                                            <Image
                                                Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                                                Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>
                                    <TextBlock
                                        Text="{x:Bind Name}"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        Text="{x:Bind Subtitle}"
                                        Opacity="0.68"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <HyperlinkButton
                        Style="{StaticResource MoreButtonStyle}"
                        Content="查看更多专辑"
                        Visibility="{x:Bind ViewModel.HasMoreAlbums, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                        Click="OnMoreAlbumsClick" />
                </StackPanel>

                <!-- Artists section -->
                <StackPanel
                    Style="{StaticResource SectionContainerStyle}"
                    Visibility="{x:Bind ViewModel.HasArtists, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="歌手" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Artists, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout
                                MinColumnSpacing="14"
                                MinItemWidth="150"
                                MinRowSpacing="18"
                                ItemsJustification="Start"
                                Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:SearchItemInfo">
                                <StackPanel Width="150" Spacing="10" Background="Transparent" Tag="{x:Bind Id}" Tapped="OnArtistTapped">
                                    <Border Background="#111111" CornerRadius="75">
                                        <Grid Width="150" Height="150">
                                            <Image
                                                Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                                                Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>
                                    <TextBlock
                                        Text="{x:Bind Name}"
                                            HorizontalAlignment="Left"
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            TextAlignment="Left"
                                            TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <HyperlinkButton
                        Style="{StaticResource MoreButtonStyle}"
                        Content="查看更多歌手"
                        Visibility="{x:Bind ViewModel.HasMoreArtists, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                        Click="OnMoreArtistsClick" />
                </StackPanel>

                <!-- Playlists section -->
                <StackPanel
                    Style="{StaticResource SectionContainerStyle}"
                    Visibility="{x:Bind ViewModel.HasPlaylists, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="歌单" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Playlists, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout
                                MinColumnSpacing="14"
                                MinItemWidth="150"
                                MinRowSpacing="18"
                                ItemsJustification="Start"
                                Orientation="Horizontal" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:SearchItemInfo">
                                <StackPanel Width="150" Spacing="10" Background="Transparent" Tag="{x:Bind Id}" Tapped="OnPlaylistTapped">
                                    <Border Background="#141414" CornerRadius="14">
                                        <Grid Width="150" Height="150">
                                            <Image
                                                Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                                                Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>
                                    <TextBlock
                                        Text="{x:Bind Name}"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        TextTrimming="CharacterEllipsis"
                                        MaxLines="2"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Text="{x:Bind Subtitle}"
                                        Opacity="0.68"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                    <HyperlinkButton
                        Style="{StaticResource MoreButtonStyle}"
                        Content="查看更多歌单"
                        Visibility="{x:Bind ViewModel.HasMorePlaylists, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                        Click="OnMorePlaylistsClick" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        </Grid>
    </Grid>
</Page>
