<Page
    x:Class="YPM.UI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:YPM.UI.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <helpers:Base64ImageSourceConverter x:Key="Base64ImageSourceConverter" />
    </Page.Resources>

    <ScrollViewer>
        <StackPanel MaxWidth="700" HorizontalAlignment="Left" Padding="40,24,40,40" Spacing="28">

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <FontIcon
                    Grid.Column="0"
                    Glyph="{x:Bind SettingsGlyph}"
                    FontSize="28"
                    VerticalAlignment="Center" />
                <TextBlock
                    Grid.Column="1"
                    Text="设置"
                    FontSize="28"
                    FontWeight="Bold"
                    VerticalAlignment="Center" />
            </Grid>

            <StackPanel Spacing="12">
                <TextBlock Text="账户" FontSize="13" FontWeight="SemiBold" Opacity="0.5" />

                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12"
                    Padding="20,16"
                    Visibility="{x:Bind LoginVM.ShowLogoutVisibility, Mode=OneWay}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="44" Height="44" CornerRadius="22" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <FontIcon Glyph="{x:Bind UserGlyph}" FontSize="20" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind LoginVM.CurrentUserName, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="已登录" FontSize="13" Opacity="0.5" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="退出登录" Command="{x:Bind LoginVM.LogoutCommand}" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- QR Login -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12"
                    Padding="24,20"
                    Visibility="{x:Bind LoginVM.ShowQrVisibility, Mode=OneWay}">
                    <StackPanel Spacing="16" HorizontalAlignment="Left" MaxWidth="320">
                        <TextBlock Text="{x:Bind LoginVM.WelcomeText, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Left" />
                        <Border Width="200" Height="200" HorizontalAlignment="Left" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Rectangle RadiusX="12" RadiusY="12">
                                <Rectangle.Fill>
                                    <ImageBrush Stretch="Fill" ImageSource="{x:Bind LoginVM.QrImageBase64, Converter={StaticResource Base64ImageSourceConverter}, Mode=OneWay}" />
                                </Rectangle.Fill>
                            </Rectangle>
                        </Border>
                        <TextBlock Text="{x:Bind LoginVM.DescriptionText, Mode=OneWay}" HorizontalAlignment="Left" TextAlignment="Left" TextWrapping="WrapWholeWords" Opacity="0.6" FontSize="13" />
                        <TextBlock Text="{x:Bind LoginVM.Status, Mode=OneWay}" HorizontalAlignment="Left" Opacity="0.8" />
                        <Button Content="刷新二维码" Command="{x:Bind LoginVM.RefreshQrCodeCommand}" HorizontalAlignment="Left" Width="140" />
                    </StackPanel>
                </Border>

                <!-- Phone Login -->
                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12"
                    Padding="24,20"
                    Visibility="{x:Bind LoginVM.ShowPhoneLoginVisibility, Mode=OneWay}">
                    <StackPanel Spacing="16" HorizontalAlignment="Left" MaxWidth="320">
                        <TextBlock Text="手机号登录" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Left" />
                        <TextBlock Text="输入手机号获取验证码后登录" HorizontalAlignment="Left" TextAlignment="Left" Opacity="0.6" FontSize="13" />

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                PlaceholderText="区号"
                                Text="{x:Bind LoginVM.CountryCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                InputScope="Number" />
                            <TextBox
                                Grid.Column="1"
                                PlaceholderText="手机号"
                                Text="{x:Bind LoginVM.PhoneNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                InputScope="Number" />
                        </Grid>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                PlaceholderText="验证码"
                                Text="{x:Bind LoginVM.CaptchaCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                InputScope="Number" />
                            <Button
                                Grid.Column="1"
                                Content="{x:Bind LoginVM.CaptchaCountdownText, Mode=OneWay}"
                                Command="{x:Bind LoginVM.SendCaptchaCommand}"
                                MinWidth="110" />
                        </Grid>

                        <TextBlock
                            Text="{x:Bind LoginVM.CaptchaStatus, Mode=OneWay}"
                            HorizontalAlignment="Left"
                            Opacity="0.8"
                            FontSize="12" />

                        <Button
                            Content="登录"
                            Command="{x:Bind LoginVM.PhoneLoginCommand}"
                            HorizontalAlignment="Left"
                            Width="200"
                            Style="{StaticResource AccentButtonStyle}" />

                        <TextBlock
                            Text="{x:Bind LoginVM.LoginStatus, Mode=OneWay}"
                            HorizontalAlignment="Left"
                            Opacity="0.8"
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                    </StackPanel>
                </Border>

                <!-- Login mode switch -->
                <StackPanel
                    Spacing="8"
                    HorizontalAlignment="Left"
                    Visibility="{x:Bind LoginVM.ShowLoginModeSwitchVisibility, Mode=OneWay}">
                    <Button
                        Content="切换到手机号登录"
                        Command="{x:Bind LoginVM.SwitchToPhoneLoginCommand}"
                        Visibility="{x:Bind LoginVM.ShowQrActionsVisibility, Mode=OneWay}"
                        HorizontalAlignment="Left" />
                    <Button
                        Content="切换到二维码登录"
                        Command="{x:Bind LoginVM.SwitchToQrLoginCommand}"
                        Visibility="{x:Bind LoginVM.ShowPhoneLoginActionsVisibility, Mode=OneWay}"
                        HorizontalAlignment="Left" />
                </StackPanel>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="语言" FontSize="13" FontWeight="SemiBold" Opacity="0.5" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20,16">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind GlobeGlyph}" FontSize="20" VerticalAlignment="Center" />
                        <ComboBox
                            Grid.Column="1"
                            ItemsSource="{x:Bind ViewModel.LanguageOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}"
                            HorizontalAlignment="Right"
                            MinWidth="180" />
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="外观" FontSize="13" FontWeight="SemiBold" Opacity="0.5" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20,16">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="{x:Bind PaletteGlyph}" FontSize="20" VerticalAlignment="Center" />
                            <ComboBox
                                Grid.Column="1"
                                ItemsSource="{x:Bind ViewModel.AppearanceOptions, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedAppearance, Mode=TwoWay}"
                                HorizontalAlignment="Right"
                                MinWidth="180" />
                        </Grid>

                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE7C1;" FontSize="20" VerticalAlignment="Center" />
                            <ToggleSwitch
                                Grid.Column="1"
                                Header="毛玻璃背景效果"
                                IsOn="{x:Bind ViewModel.EnableAcrylic, Mode=TwoWay}"
                                HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="启动" FontSize="13" FontWeight="SemiBold" Opacity="0.5" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20,16">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind HomeGlyph}" FontSize="20" VerticalAlignment="Center" />
                        <ComboBox
                            Grid.Column="1"
                            ItemsSource="{x:Bind ViewModel.StartPageOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedStartPage, Mode=TwoWay}"
                            HorizontalAlignment="Right"
                            MinWidth="180" />
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="音质" FontSize="13" FontWeight="SemiBold" Opacity="0.5" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20,16">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind SpeakerGlyph}" FontSize="20" VerticalAlignment="Center" />
                        <ComboBox
                            Grid.Column="1"
                            ItemsSource="{x:Bind ViewModel.QualityOptions, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedQuality, Mode=TwoWay}"
                            HorizontalAlignment="Right"
                            MinWidth="180" />
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="音乐缓存" FontSize="13" FontWeight="SemiBold" Opacity="0.5" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20,16">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="{x:Bind SpeakerGlyph}" FontSize="20" VerticalAlignment="Center" />
                            <ToggleSwitch
                                Grid.Column="1"
                                Header="自动缓存播放过的歌曲"
                                IsOn="{x:Bind ViewModel.AutoCacheSongs, Mode=TwoWay}"
                                HorizontalAlignment="Right" />
                        </Grid>

                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="{x:Bind StorageGlyph}" FontSize="20" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock
                                    Text="{x:Bind ViewModel.CurrentCacheSizeText, Mode=OneWay}"
                                    FontSize="14"
                                    FontWeight="SemiBold" />
                                <Button
                                    Content="清除音乐缓存"
                                    Click="OnClearCacheClick"
                                    HorizontalAlignment="Left" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="{x:Bind FolderGlyph}" FontSize="20" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="音乐缓存位置" FontSize="14" FontWeight="SemiBold" />
                                <TextBox
                                    x:Name="CacheLocationBox"
                                    Text="{x:Bind ViewModel.CacheLocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="{x:Bind ViewModel.CacheLocationPlaceholder, Mode=OneWay}"
                                    IsReadOnly="True" />
                                <Button
                                    Content="选择文件夹"
                                    Click="OnPickCacheFolderClick"
                                    HorizontalAlignment="Left" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="{x:Bind SizeGlyph}" FontSize="20" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="音乐缓存大小限制" FontSize="14" FontWeight="SemiBold" />
                                <Slider
                                    x:Name="CacheLimitSlider"
                                    Minimum="512"
                                    Maximum="10240"
                                    Value="{x:Bind ViewModel.CacheLimitValue, Mode=TwoWay}"
                                    StepFrequency="256"
                                    ValueChanged="OnCacheLimitChanged" />
                                <TextBlock
                                    x:Name="CacheLimitLabel"
                                    Text="{x:Bind ViewModel.CacheLimitText, Mode=OneWay}"
                                    FontSize="13"
                                    Opacity="0.6" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="接口缓存" FontSize="13" FontWeight="SemiBold" Opacity="0.5" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20,16">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind RefreshGlyph}" FontSize="20" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="清除后所有页面数据将重新从网络获取" FontSize="13" Opacity="0.6" />
                            <Button
                                Content="清除接口缓存"
                                Click="OnClearApiCacheClick"
                                HorizontalAlignment="Left" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="Real IP" FontSize="13" FontWeight="SemiBold" Opacity="0.5" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20,16">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="{x:Bind WifiGlyph}" FontSize="20" VerticalAlignment="Center" />
                            <ToggleSwitch
                                Grid.Column="1"
                                Header="启用 Real IP"
                                IsOn="{x:Bind ViewModel.EnableRealIP, Mode=TwoWay}"
                                HorizontalAlignment="Right" />
                        </Grid>
                        <TextBox
                            PlaceholderText="IP 地址"
                            Text="{x:Bind ViewModel.RealIP, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="关于" FontSize="13" FontWeight="SemiBold" Opacity="0.5" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20,16">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="{x:Bind InfoGlyph}" FontSize="20" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Fusion" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock
                                Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                FontSize="13"
                                Opacity="0.6" />
                            <TextBlock
                                Text="WinUI 3 桌面客户端"
                                FontSize="13"
                                Opacity="0.5" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
