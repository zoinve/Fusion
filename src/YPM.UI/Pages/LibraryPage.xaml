<Page
    x:Class="YPM.UI.Pages.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:YPM.UI.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:model="using:YPM.Core.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:UriImageSourceConverter x:Key="UriImageSourceConverter" />
        <helpers:StringToBooleanConverter x:Key="StringToBooleanConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Page.Resources>

    <ScrollViewer x:Name="MainScrollViewer">
        <StackPanel MaxWidth="1100" HorizontalAlignment="Left" Padding="40,24,40,40" Spacing="28">

                <!-- Error -->
                <InfoBar
                    IsOpen="{x:Bind ViewModel.ErrorMessage, Converter={StaticResource StringToBooleanConverter}, Mode=OneWay}"
                    Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    Severity="Error" />

                <!-- Loading -->
                <ProgressRing
                    Width="40" Height="40"
                    HorizontalAlignment="Center"
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

                <!-- Login Prompt -->
                <Border
                    x:Name="LoginPrompt"
                    Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="12"
                    Padding="40,32">
                    <StackPanel HorizontalAlignment="Center" Spacing="12">
                        <FontIcon Glyph="&#xE77B;" FontSize="48" Opacity="0.4" />
                        <TextBlock Text="请先登录以查看音乐库" FontSize="16" Opacity="0.6" />
                    </StackPanel>
                </Border>

                <!-- User Header -->
                <StackPanel Spacing="6" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <Border Width="48" Height="48" CornerRadius="24" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Image
                                Width="48" Height="48"
                                Source="{x:Bind ViewModel.UserAvatar, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                                Stretch="UniformToFill" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                Text="{x:Bind ViewModel.UserName, Mode=OneWay}"
                                FontSize="20"
                                FontWeight="SemiBold" />
                            <TextBlock Text="我的" FontSize="12" Opacity="0.5" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Liked Songs Card -->
                    <Button
                        Click="OnLikedSongsClick"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="12"
                        Padding="18"
                        HorizontalAlignment="Left"
                        HorizontalContentAlignment="Stretch">
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Cover: fallback single image when no track covers -->
                            <Border
                                Grid.Column="0"
                                Width="216" Height="216"
                                CornerRadius="8"
                                Visibility="{x:Bind ViewModel.HasLikedSongsCovers, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                <Image
                                    Width="216" Height="216"
                                    Source="{x:Bind ViewModel.LikedSongsLatestCoverUrl, Mode=OneWay, Converter={StaticResource UriImageSourceConverter}}"
                                    Stretch="UniformToFill" />
                            </Border>
                            <!-- 2x2 cover grid -->
                            <ItemsRepeater
                                Grid.Column="0"
                                Width="216" Height="216"
                                ItemsSource="{x:Bind ViewModel.LikedSongsCovers, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.HasLikedSongsCovers, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout
                                        MinColumnSpacing="4"
                                        MinItemWidth="106"
                                        MinRowSpacing="4"
                                        MaximumRowsOrColumns="2"
                                        ItemsJustification="Start"
                                        Orientation="Horizontal" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border Width="106" Height="106" CornerRadius="8">
                                            <Image
                                                Width="106" Height="106"
                                                Source="{x:Bind Mode=OneWay, Converter={StaticResource UriImageSourceConverter}}"
                                                Stretch="UniformToFill" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                            <!-- Text -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                <TextBlock
                                    Text="{x:Bind ViewModel.LikedSongsText, Mode=OneWay}"
                                    FontSize="16"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    Text="点击查看全部"
                                    FontSize="12"
                                    Opacity="0.5" />
                            </StackPanel>
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Tab Bar -->
                <StackPanel
                    x:Name="TabBar"
                    Orientation="Horizontal"
                    Spacing="4"
                    HorizontalAlignment="Left"
                    CornerRadius="10"
                    Padding="4">
                    <Button Style="{StaticResource TabButtonStyle}" Tag="0" Click="OnTabClick">歌单</Button>
                    <Button Style="{StaticResource TabButtonStyle}" Tag="1" Click="OnTabClick">专辑</Button>
                    <Button Style="{StaticResource TabButtonStyle}" Tag="2" Click="OnTabClick">艺人</Button>
                   
                    <Button Style="{StaticResource TabButtonStyle}" Tag="4" Click="OnTabClick">云盘</Button>
                    <Button Style="{StaticResource TabButtonStyle}" Tag="5" Click="OnTabClick">听歌排行</Button>
                </StackPanel>

                <!-- Tab: 歌单 (Playlists) -->
                <ItemsRepeater
                    x:Name="PlaylistsSection"
                    ItemsSource="{x:Bind ViewModel.Playlists, Mode=OneWay}"
                    HorizontalAlignment="Stretch"
                    Visibility="Visible">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MinColumnSpacing="14"
                            MinItemWidth="150"
                            MinRowSpacing="18"
                            ItemsJustification="Start"
                            Orientation="Horizontal" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="model:PlaylistSummary">
                            <StackPanel Width="150" Spacing="10" Background="Transparent" Tag="{x:Bind Id}" Tapped="OnPlaylistTapped">
                                <Border CornerRadius="14">
                                    <Grid Width="150" Height="150">
                                        <Image
                                            Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                                            Stretch="UniformToFill" />
                                    </Grid>
                                </Border>
                                <TextBlock
                                    Text="{x:Bind Name}"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="2"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Tab: 专辑 (Albums) -->
                <ItemsRepeater
                    x:Name="AlbumsSection"
                    ItemsSource="{x:Bind ViewModel.Albums, Mode=OneWay}"
                    HorizontalAlignment="Stretch"
                    Visibility="Collapsed">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MinColumnSpacing="14"
                            MinItemWidth="150"
                            MinRowSpacing="18"
                            ItemsJustification="Start"
                            Orientation="Horizontal" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="model:AlbumDetail">
                            <StackPanel Width="150" Spacing="10" Background="Transparent" Tag="{x:Bind Id}" Tapped="OnAlbumTapped">
                                <Border CornerRadius="14">
                                    <Grid Width="150" Height="150">
                                        <Image
                                            Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                                            Stretch="UniformToFill" />
                                    </Grid>
                                </Border>
                                <TextBlock
                                    Text="{x:Bind Name}"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis"
                                    MaxLines="2"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Text="{x:Bind Artist.Name}"
                                    FontSize="12"
                                    Opacity="0.6"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Tab: 艺人 (Artists) -->
                <ItemsRepeater
                    x:Name="ArtistsSection"
                    ItemsSource="{x:Bind ViewModel.Artists, Mode=OneWay}"
                    HorizontalAlignment="Stretch"
                    Visibility="Collapsed">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MinColumnSpacing="14"
                            MinItemWidth="130"
                            MinRowSpacing="18"
                            ItemsJustification="Start"
                            Orientation="Horizontal" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="model:ArtistSummary">
                            <StackPanel Width="130" Spacing="10" HorizontalAlignment="Left">
                                <Border Width="100" Height="100" CornerRadius="50" HorizontalAlignment="Left">
                                    <Image
                                        Width="100" Height="100"
                                        Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                                        Stretch="UniformToFill" />
                                </Border>
                                <TextBlock
                                    Text="{x:Bind Name}"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis"
                                    HorizontalAlignment="Left" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Tab: MV -->
                <ItemsRepeater
                    x:Name="MvsSection"
                    ItemsSource="{x:Bind ViewModel.Mvs, Mode=OneWay}"
                    HorizontalAlignment="Stretch"
                    Visibility="Collapsed">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MinColumnSpacing="14"
                            MinItemWidth="240"
                            MinRowSpacing="18"
                            ItemsJustification="Start"
                            Orientation="Horizontal" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="model:MvInfo">
                            <StackPanel Width="240" Spacing="8" HorizontalAlignment="Left">
                                <Border CornerRadius="10">
                                    <Grid Width="240" Height="135">
                                        <Image
                                            Source="{x:Bind CoverUrl, Converter={StaticResource UriImageSourceConverter}, Mode=OneWay}"
                                            Stretch="UniformToFill" />
                                    </Grid>
                                </Border>
                                <TextBlock
                                    Text="{x:Bind Name}"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{x:Bind ArtistName}"
                                    FontSize="12"
                                    Opacity="0.6"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Tab: 云盘 (Cloud Disk) -->
                <ListView
                    x:Name="CloudSection"
                    ItemsSource="{x:Bind ViewModel.CloudDiskTracks, Mode=OneWay}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Visibility="Collapsed"
                    IsItemClickEnabled="True"
                    ItemClick="OnCloudTrackClick"
                    SelectionMode="None"
                    ScrollViewer.VerticalScrollMode="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="model:TrackInfo">
                            <Grid Padding="8,6" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="48" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind Name}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind ArtistsText}" FontSize="12" Opacity="0.6" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{x:Bind DurationText}" FontSize="12" Opacity="0.5" VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Tab: 听歌排行 (History) -->
                <StackPanel x:Name="HistorySection" Visibility="Collapsed" Spacing="12" HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,8" HorizontalAlignment="Left">
                        <Button Style="{StaticResource TabButtonStyle}" x:Name="WeekTabButton" Tag="0" Click="OnHistoryTabClick" Content="Week" />
                        <Button Style="{StaticResource TabButtonStyle}" x:Name="AllTabButton" Tag="1" Click="OnHistoryTabClick" Content="All" />
                    </StackPanel>
                    <ListView
                        x:Name="HistoryList"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        IsItemClickEnabled="True"
                        ItemClick="OnHistoryTrackClick"
                        SelectionMode="None"
                        ScrollViewer.VerticalScrollMode="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="model:RecordItem">
                                <Grid Padding="8,6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="56" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{x:Bind PlayCount}"
                                        FontSize="13"
                                        Opacity="0.5"
                                        VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock
                                            Text="{x:Bind Song.Name}"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Text="{x:Bind Song.ArtistsText}"
                                            FontSize="12"
                                            Opacity="0.6"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Column="2"
                                        Text="{x:Bind Song.DurationText}"
                                        FontSize="12"
                                        Opacity="0.4"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
