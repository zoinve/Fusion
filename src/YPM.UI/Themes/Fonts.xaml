<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        font-family: "Microsoft YaHei", "PingFang SC", "Noto Sans SC", sans-serif
        WinUI resolves comma-separated FontFamily names left-to-right,
        falling back to the next when a font is not installed.
    -->
    <FontFamily x:Key="PrimaryFont">Microsoft YaHei, PingFang SC, Noto Sans SC</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Code, Consolas, monospace</FontFamily>

    <x:Double x:Key="CaptionFontSize">12</x:Double>
    <x:Double x:Key="BodyFontSize">14</x:Double>
    <x:Double x:Key="BodyLargeFontSize">16</x:Double>
    <x:Double x:Key="SubtitleFontSize">18</x:Double>
    <x:Double x:Key="TitleFontSize">22</x:Double>
    <x:Double x:Key="TitleLargeFontSize">28</x:Double>
    <x:Double x:Key="DisplayFontSize">36</x:Double>

</ResourceDictionary>
