<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Colors -->
    <Color x:Key="PrimaryColor">#FF335EEA</Color>
    <Color x:Key="PrimaryLightColor">#FF5B7FF0</Color>
    <Color x:Key="PrimaryDarkColor">#FF1E40C8</Color>

    <!-- Accent Colors -->
    <Color x:Key="AccentColor">#FFEB4D4B</Color>
    <Color x:Key="AccentLightColor">#FFFF6B6B</Color>

    <!-- Background -->
    <Color x:Key="PageBackgroundColor">#FFF5F5F5</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFFFF</Color>
    <Color x:Key="NavBackgroundColor">#FFFAFAFA</Color>
    <Color x:Key="PlayerBackgroundColor">#FFF0F0F0</Color>

    <!-- Text -->
    <Color x:Key="PrimaryTextColor">#FF212121</Color>
    <Color x:Key="SecondaryTextColor">#FF757575</Color>
    <Color x:Key="TertiaryTextColor">#FF9E9E9E</Color>
    <Color x:Key="InverseTextColor">#FFFFFFFF</Color>

    <!-- Border -->
    <Color x:Key="BorderLightColor">#FFE0E0E0</Color>
    <Color x:Key="BorderMediumColor">#FFBDBDBD</Color>

    <!-- Status -->
    <Color x:Key="SuccessColor">#FF4CAF50</Color>
    <Color x:Key="WarningColor">#FFFF9800</Color>
    <Color x:Key="ErrorColor">#FFF44336</Color>

    <!-- Music-specific -->
    <Color x:Key="TrackHoverColor">#FFF5F5F5</Color>
    <Color x:Key="TrackSelectedColor">#FFE8EAF6</Color>
    <Color x:Key="LikeActiveColor">#FFEB4D4B</Color>

</ResourceDictionary>
